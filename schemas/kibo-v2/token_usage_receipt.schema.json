      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "call_purpose": {
      "type": "string"
    },
    "contract_hash": {
      "maxLength": 64,
      "minLength": 64,
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "estimated": {
      "type": "boolean"
    },
    "estimation_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "input_tokens": {
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "latency_ms": {
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "model": {
      "type": "string"
    },
    "monetary_cost": {
      "minimum": 0,
      "type": [
        "number",
        "null"
      ]
    },
    "output_tokens": {
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "provider": {
      "type": "string"
    },
    "receipt_id": {
      "minLength": 1,
      "type": "string"
